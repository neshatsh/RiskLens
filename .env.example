# Copy this file to .env and fill in your keys — .env is gitignored

# "openai" or "anthropic"
LLM_PROVIDER=openai

OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o

ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-6

# free at fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=

# free at newsapi.org
NEWS_API_KEY=

LOG_LEVEL=INFO

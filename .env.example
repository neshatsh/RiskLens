# .env.example — copy to .env and fill in your keys
# Never commit .env to version control

# ── LLM Configuration ──────────────────────────────────────────────────────
# Choose your LLM provider: "openai" or "anthropic"
LLM_PROVIDER=openai

# OpenAI API key (get at platform.openai.com)
OPENAI_API_KEY=sk-...

# OpenAI model — gpt-4o recommended for best risk analysis quality
OPENAI_MODEL=gpt-4o

# Anthropic API key (get at console.anthropic.com) — optional, used if LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-6

# ── Data APIs ──────────────────────────────────────────────────────────────
# FRED API key (get free at fred.stlouisfed.org/docs/api/api_key.html)
FRED_API_KEY=your_fred_api_key_here

# NewsAPI key (get free at newsapi.org) — optional, falls back to GNews without it
NEWS_API_KEY=your_newsapi_key_here

# ── App Configuration ──────────────────────────────────────────────────────
# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
